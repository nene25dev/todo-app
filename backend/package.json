{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test dotenv -e .env.test -- tsx --test --test-concurrency=1 test/**/*.test.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/backend/src/index.js",
    "reset": "prisma migrate reset --force",
    "seed": "prisma db seed",
    "seed:dev": "tsx prisma/seed.dev.ts",
    "seed:test": "dotenv -e .env.test -- tsx prisma/seed.dev.ts",
    "seed:prod": "dotenv -e .env.production -- tsx prisma/seed.prod.ts",
    "db:push:test": "dotenv -e .env.test -- prisma db push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.4.2",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.4.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
