{
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev:b": "npm run dev --prefix ./backend",
    "dev:f": "npm run dev --prefix ./frontend",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:b\" \"npm run dev:f\""
  }
}
